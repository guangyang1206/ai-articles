    </div>
    <div class="tl-row">
      <div class="tl-dot-col">
        <div class="tl-dot active"></div>
        <div class="tl-line"></div>
      </div>
      <div class="tl-text">
        <div class="tl-date">5月9日 🎯</div>
        <div class="tl-value" style="color:var(--blue)">500 亿 RMB</div>
